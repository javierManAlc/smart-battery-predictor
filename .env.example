# ==============================================================================
# PLANTILLA DE CONFIGURACIÓN LOCAL (.env.example)
# Copia este archivo, renombralo como '.env' en la raíz y añade tus valores reales.
# ==============================================================================

# Token de acceso para la API de ESIOS (Red Eléctrica de España)
# Consíguelo solicitándolo en: consultasios@ree.es
ESIOS_API_TOKEN=tu_token_aqui

# Entorno de ejecución (True para desarrollo con prints detallados, False para producción)
DEBUG_MODE=True